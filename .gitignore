# Root .gitignore for Codebreaker

# Dependencies & Package Managers
node_modules/
.pnp
.pnp.*
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-debug.log*

# Python / Backend
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.venv
.python-version

# Next.js / Frontend
.next/
out/
next-env.d.ts
*.tsbuildinfo

# OS / Misc
.DS_Store
*.pem
.env*
.vercel

# IDEs
.vscode/
.idea/
*.swp
*.swo
